if(selected.value===correct){fb.innerHTML='&#10004; <strong>正解！</strong>\u3000'+explanation;fb.className='feedback correct'}
else{fb.innerHTML='&#10008; <strong>不正解。</strong>正解は <strong>'+correct+'</strong> です。\u3000'+explanation;fb.className='feedback incorrect'}
}
